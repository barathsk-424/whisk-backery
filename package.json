{
  "name": "bakery-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "thewhisk"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace=thewhisk run dev",
    "dev:backend": "npm --workspace=backend run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm --workspace=thewhisk run build",
    "preview": "npm --workspace=thewhisk run preview"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
